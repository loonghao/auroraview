{
  "name": "auroraview-gallery",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "install:playwright": "playwright install chromium --with-deps",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test --config ../tests/e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --config ../tests/e2e/playwright.config.ts --headed",
    "test:e2e:report": "playwright show-report ../tests/e2e/report"
  },
  "dependencies": {
    "@auroraview/sdk": "file:../packages/auroraview-sdk",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.207.0",
    "@opentelemetry/instrumentation": "^0.207.0",
    "@opentelemetry/instrumentation-document-load": "^0.54.0",
    "@opentelemetry/instrumentation-fetch": "^0.207.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.207.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-trace-base": "^2.1.0",
    "@opentelemetry/sdk-trace-web": "^2.1.0",
    "@opentelemetry/semantic-conventions": "^1.37.0",
    "@sentry/react": "^10.22.0",
    "class-variance-authority": "^0.7.1",

    "clsx": "^2.1.1",

    "gsap": "^3.14.2",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^7.2.7"
  }
}
