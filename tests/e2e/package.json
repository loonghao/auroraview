{
  "name": "auroraview-e2e-tests",
  "version": "1.0.0",
  "private": true,
  "description": "E2E tests for AuroraView Gallery using Playwright",
  "type": "module",
  "scripts": {
    "test": "playwright test --config playwright.config.ts",
    "test:headed": "playwright test --config playwright.config.ts --headed",
    "test:debug": "playwright test --config playwright.config.ts --headed --debug",
    "report": "playwright show-report report",
    "install:playwright": "playwright install chromium --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.2",
    "typescript": "^5.9.3"
  }
}
