# Ensure shell scripts and YAML files use LF line endings (required for CI)
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows-specific scripts
*.ps1 text eol=crlf
*.bat text eol=crlf

# Python files
*.py text eol=lf

# JavaScript/TypeScript
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
